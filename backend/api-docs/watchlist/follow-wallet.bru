meta {
  name: Follow Wallet
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/watchlist/follow
  body: json
  auth: inherit
}

body:json {
  {
    "wallet_address": "{{walletAddress}}",
    "chain": "{{chain}}",
    "recommendation": "conditional_follow",
    "conditions": ["min_liquidity", "min_mcap"],
    "email_notify": true
  }
}
